<Window x:Class="A2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:A2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <EventSetter Event="TextChanged" Handler="TextChanged"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition />
        </Grid.RowDefinitions>
        <GroupBox Grid.Row="0" Header="扫描的IP地址范围" VerticalAlignment="Center"  Padding="10">
            <DockPanel>
                <Label DockPanel.Dock="Left" Content="地址前缀："/>
                <TextBox Name="txt1" Width="250" />
                <Label Content="起始值：" Margin="15 0 0 0"/>
                <TextBox Name="txt2" Width="100" />
                <Label Content="终止值：" Margin="15 0 0 0"/>
                <TextBox Name="txt3" Width="100" />
                <Button Name="btn1" Width="60" VerticalAlignment="Center" Content="开始扫描" Click="btn1_Click"/>
            </DockPanel>
        </GroupBox>
        <Label x:Name="Prompt" Grid.Row="1" Background="Red" Foreground="White" Content="IP地址有错，请更正！"  HorizontalContentAlignment="Center"/>
        <GroupBox Grid.Row="2" Header="扫描信息">
            <ListBox Name="info"/>
        </GroupBox>
    </Grid>
</Window>
