<Window x:Class="Client.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="游戏聊天室" Height="480" Width="700">
    <Window.Resources>
        <Image x:Key="battle" Source="/images/battle.png"/>
        <Image x:Key="Bronze" Source="/images/Bronze.png"/>
        <Image x:Key="Gold" Source="/images/Gold.png"/>
        <Image x:Key="Silver" Source="/images/Silver.png"/>
        <Image x:Key="Diamond" Source="/images/Diamond.png"/>
        <Image x:Key="Crown" Source="/images/Crown.png"/>
        <Image x:Key="avatar00" Source="/images/portrait/avatar00.png"/>
        <Image x:Key="avatar01" Source="/images/portrait/avatar01.png"/>
        <Image x:Key="avatar02" Source="/images/portrait/avatar02.png"/>
        <Image x:Key="avatar03" Source="/images/portrait/avatar03.png"/>
        <Image x:Key="avatar04" Source="/images/portrait/avatar04.png"/>
        <Image x:Key="avatar05" Source="/images/portrait/avatar05.png"/>
        <Image x:Key="avatar06" Source="/images/portrait/avatar06.png"/>
        <Image x:Key="avatar07" Source="/images/portrait/avatar07.png"/>
        <Image x:Key="avatar08" Source="/images/portrait/avatar08.png"/>
        <Image x:Key="avatar09" Source="/images/portrait/avatar09.png"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="343"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Background="Cornsilk" Margin="5 5 0 5">
            <Image Name="Dan_picture"   Width="40"  Source="images/dishu.png" />
            <TextBlock Text="用户名：" DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <TextBlock x:Name="textBoxUserName" Text="未登录" Width="100" VerticalAlignment="Center"/>
            <TextBlock x:Name="star_number" Text="0星玩家" Width="100" VerticalAlignment="Center"/>
            <Button Name="Show_record" Content="查询历史战绩"   DockPanel.Dock="Left" Padding="10 0 10 0" Margin="5" Click="Show_record_Click"/>
            <!--<Button Name="btnLogin" Content="登录" Click="btnLogin_Click" DockPanel.Dock="Left" Padding="10 0 10 0" Margin="5"/>
            <Button Name="btnLogout" Content="退出" Click="btnLogout_Click" DockPanel.Dock="Left" Padding="10 0 10 0" Margin="5"/>-->
            <!--<TextBlock Name="serviceTextBlock" Text="服务端地址：" Margin="5 0 0 0" VerticalAlignment="Center"/>-->
        </DockPanel>
        <Grid Name="gridRooms" Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                 Text="游戏大厅" Background="Beige" TextAlignment="Center"/>
            <Grid Grid.Row="1">
                <ListBox Name="listBoxRooms"
                 Background="AntiqueWhite"
                 ScrollViewer.VerticalScrollBarVisibility="Visible"/>
            </Grid>
        </Grid>


        <Grid Name="gridRoom" Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <StackPanel Name="stackPanelRoomTip" Grid.Row="0"
                    Background="Aqua" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Name="textBlockRoomNumber" Text="房间号：" Margin="5 0 0 0"/>
                <TextBlock Name="textBlockBlackUserName" Margin="10 0 0 0" Width="107"/>
                <TextBlock Name="textBlockWhiteUserName"  Margin="10 0 0 0"/>
            </StackPanel>
            <Canvas Name="canvas1" Grid.Row="1">
                <Image Name="imageGameTable" Stretch="Fill" Source="images/dadishu.jpg" MouseDown="Image_MouseDown" Height="384" Width="343" />
                <Image Name="pictureBox1" Grid.Column="1" HorizontalAlignment="Left" Height="50" Grid.Row="1" VerticalAlignment="Top" Width="60" Canvas.Left="58" Canvas.Top="105" Source="images/dishu.png" MouseDown="picture1_MouseDown" />
                <Image Name="pictureBox2" Grid.Column="1" HorizontalAlignment="Left" Height="50" Grid.Row="1" VerticalAlignment="Top" Width="60" Canvas.Top="245" Source="images/dishu.png" MouseDown="picture2_MouseDown"/>
                <Image Name="pictureBox3" Grid.Column="1" HorizontalAlignment="Left" Height="50" Grid.Row="1" VerticalAlignment="Top" Width="60" Canvas.Left="209" Canvas.Top="105" Source="images/dishu.png" MouseDown="picture3_MouseDown" RenderTransformOrigin="0.267,0.811"/>
                <Image Name="pictureBox4" Grid.Column="1" HorizontalAlignment="Left" Height="50" Grid.Row="1" VerticalAlignment="Center" Width="60" Canvas.Left="8" Canvas.Top="155" Source="images/dishu.png" MouseDown="picture4_MouseDown" RenderTransformOrigin="0.08,0.491"/>
                <Image Name="pictureBox5" Grid.Column="1" HorizontalAlignment="Left" Height="50" Grid.Row="1" VerticalAlignment="Top" Width="60" Canvas.Left="115" Canvas.Top="167" Source="images/dishu.png" MouseDown="picture5_MouseDown" RenderTransformOrigin="-0.103,0.843"/>
                <Image Name="pictureBox6" Grid.Column="1" HorizontalAlignment="Left" Height="50" Grid.Row="1" VerticalAlignment="Top" Width="60" Canvas.Left="209" Canvas.Top="205" Source="images/dishu.png" MouseDown="picture6_MouseDown"/>
                <Image Name="pictureBox7" Grid.Column="1" HorizontalAlignment="Left" Height="50" Grid.Row="1" VerticalAlignment="Top" Width="60" Canvas.Left="275" Canvas.Top="150" Source="images/dishu.png" MouseDown="picture7_MouseDown" RenderTransformOrigin="4.453,-1.069"/>
                <Image Name="pictureBox8" Grid.Column="1" HorizontalAlignment="Center" Height="50" Grid.Row="1" VerticalAlignment="Top" Width="60" Canvas.Left="115" Canvas.Top="258" Source="images/dishu.png" MouseDown="picture8_MouseDown" RenderTransformOrigin="0.097,0.579"/>
                <Image Name="pictureBox9" Grid.Column="1" HorizontalAlignment="Left" Height="50" Grid.Row="1" VerticalAlignment="Center" Width="60" Canvas.Left="275" Canvas.Top="245" Source="images/dishu.png" MouseDown="picture9_MouseDown"/>
                <Image Name="pictureBox10" Grid.Column="1" HorizontalAlignment="Left" Height="50" Grid.Row="1" VerticalAlignment="Top" Width="60" Canvas.Left="209" Canvas.Top="296" Source="images/dishu.png" MouseDown="picture10_MouseDown"/>
            </Canvas>
            <DockPanel Grid.Row="2" Background="AliceBlue" Margin="0 5 0 5">
                <Button Name="btnStart" Content="游戏" Click="btnStart_Click" Margin="5 0 0 0" Width="40"/>
                <Button Name="btnReturn" Content="返回大厅" Click="btnReturn_Click" Margin="5 0 0 0" Width="56"/>
                <TextBlock Text="对话：" Margin="5 0 0 0" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <Button Name="btnSend" Click="btnSend_Click" Content="发送" Width="40" DockPanel.Dock="Right" Margin="5 0 5 0"/>
                <TextBox Name="textBoxTalk" KeyDown="textBoxTalk_KeyDown"/>
            </DockPanel>
        </Grid>

        <Grid Name="gridMessage" Grid.Row="1" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="200"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <ListBox Name="listBoxMessage"
                     BorderThickness="1" Padding="0 5 0 0"
                     ScrollViewer.VerticalScrollBarVisibility="Visible"  Grid.Row="0"  />
            <TextBlock Name="textBlockMessage" Grid.Row="1"
                 Text="在线人数：0" Background="Beige" TextAlignment="Center" />
            <ListBox Name="listBoxUser" Grid.Row="2"
                 Background="AntiqueWhite" MouseLeftButtonDown="listBoxUser_MouseLeftButtonDown"
                 ScrollViewer.VerticalScrollBarVisibility="Visible"   />
        </Grid>
    </Grid>
</Window>
